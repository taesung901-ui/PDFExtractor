<Window x:Class="PDFExtractor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDF 페이지 추출기"
        Width="980"
        Height="760"
        MinWidth="880"
        MinHeight="640"
        Background="#F3EEE4"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFDF8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1D4D4F" />
        <SolidColorBrush x:Key="TextBrush" Color="#1B1F23" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#66707A" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8D1C4" />
        <SolidColorBrush x:Key="HintBrush" Color="#EFF5F5" />

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="#E8F0ED" />
            <Setter Property="BorderBrush" Value="#D5E3DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Border Background="{StaticResource CardBrush}"
                    CornerRadius="24"
                    Padding="34"
                    BorderBrush="#E3DBCF"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       Text="PDF 페이지 추출기" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="쉼표로 구분한 범위마다 별도 PDF를 만들고, 저장 폴더를 비워두면 원본 파일 옆에 자동 폴더를 생성합니다." />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="24,0,0,0"
                                Padding="18"
                                Background="{StaticResource HintBrush}"
                                CornerRadius="16"
                                BorderBrush="#D8E6E4"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Text="동작 예시" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="입력: 1-3, 5, 7-9" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="결과: 3개의 PDF 생성" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="출력: 원본제목_1-3.pdf, 원본제목_5.pdf ..." />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="원본 PDF" />
                            <Border x:Name="SourceDropBorder"
                                    Padding="14"
                                    Background="#FCFBF8"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    AllowDrop="True"
                                    PreviewDragOver="SourceDropBorder_OnPreviewDragOver"
                                    DragLeave="SourceDropBorder_OnDragLeave"
                                    Drop="SourceDropBorder_OnDrop">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="128" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SourcePdfTextBox"
                                                 Grid.Column="0"
                                                 Style="{StaticResource InputBoxStyle}"
                                                 TextChanged="SourcePdfTextBox_OnTextChanged" />
                                        <Button Grid.Column="1"
                                                Margin="12,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BrowseSourceButton_OnClick"
                                                Content="파일 선택" />
                                    </Grid>
                                    <TextBlock x:Name="SourceInfoTextBlock"
                                               Style="{StaticResource HintStyle}"
                                               Text="PDF를 끌어놓거나 직접 선택하세요." />
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,24,0,0"
                                       Style="{StaticResource LabelStyle}"
                                       Text="추출할 페이지 범위" />
                            <TextBox x:Name="RangeTextBox"
                                     Style="{StaticResource InputBoxStyle}"
                                     TextChanged="RangeTextBox_OnTextChanged"
                                     PreviewTextInput="RangeTextBox_OnPreviewTextInput" />
                            <Border x:Name="RangeValidationBorder"
                                    Margin="0,8,0,0"
                                    Padding="10,8"
                                    Background="#F7FBFA"
                                    BorderBrush="#D7E7E2"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock x:Name="RangeValidationTextBlock"
                                           FontSize="12"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"
                                           Text="페이지 범위를 입력하면 바로 형식을 확인합니다." />
                            </Border>
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="숫자, 쉼표, 하이픈만 입력할 수 있습니다. 예: 1-3, 5, 7-9" />

                            <TextBlock Margin="0,24,0,0"
                                       Style="{StaticResource LabelStyle}"
                                       Text="저장 폴더 (선택 사항)" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="128" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputFolderTextBox"
                                         Grid.Column="0"
                                         Style="{StaticResource InputBoxStyle}"
                                         TextChanged="OutputFolderTextBox_OnTextChanged" />
                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BrowseOutputFolderButton_OnClick"
                                        Content="폴더 선택" />
                            </Grid>
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="비워두면 원본 PDF가 있는 폴더 아래에 자동으로 '분리-원본제목' 폴더를 만듭니다." />

                            <CheckBox x:Name="OpenFolderCheckBox"
                                      Margin="0,22,0,0"
                                      Foreground="{StaticResource TextBrush}"
                                      Checked="OpenFolderCheckBox_OnChanged"
                                      Unchecked="OpenFolderCheckBox_OnChanged"
                                      Content="완료 후 출력 폴더 열기" />
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="추출이 끝나면 생성된 폴더를 Explorer로 바로 엽니다." />

                            <Button x:Name="ExtractButton"
                                    Margin="0,26,0,0"
                                    Width="180"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ExtractButton_OnClick"
                                    Content="PDF 추출" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="28,0,0,0">
                            <Border Padding="18"
                                    Background="#F7FBFA"
                                    BorderBrush="#D7E7E2"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Text="기본 출력 폴더" />
                                    <TextBlock x:Name="OutputPreviewTextBlock"
                                               Margin="0,12,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="18"
                                    Background="#FAF7F0"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="상태" />
                                    <TextBlock x:Name="StatusTextBlock"
                                               Margin="0,12,0,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="준비됨" />
                                    <TextBlock x:Name="StatusDetailTextBlock"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="18"
                                    Background="#FFF8EE"
                                    BorderBrush="#E7D7BD"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="최근 생성 파일" />
                                    <TextBlock x:Name="CreatedFilesEmptyTextBlock"
                                               Margin="0,12,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="아직 생성된 파일이 없습니다." />
                                    <ListBox x:Name="CreatedFilesListBox"
                                             Margin="0,12,0,0"
                                             Height="210"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionChanged="CreatedFilesListBox_OnSelectionChanged"
                                             MouseDoubleClick="CreatedFilesListBox_OnMouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="12"
                                                        Background="#FFFDF8"
                                                        BorderBrush="#E9DCC4"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <StackPanel>
                                                        <TextBlock FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   Text="{Binding FileName}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding FullPath}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <UniformGrid Margin="0,12,0,0"
                                                 Columns="2">
                                        <Button x:Name="OpenSelectedFileButton"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OpenSelectedFileButton_OnClick"
                                                Content="파일 열기" />
                                        <Button x:Name="OpenSelectedFolderButton"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OpenSelectedFolderButton_OnClick"
                                                Content="폴더 열기" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
